@{
    ViewData["Title"] = "הרשמת לקוח חדש";
}

<style>
    body {
        background: url('https://images.unsplash.com/photo-1490750967868-58cb75069ed6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80') no-repeat center center fixed;
        background-size: cover;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.3);
        z-index: -1;
    }

    .access-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        padding: 30px;
        border: 2px solid #a3cfbb;
    }

    .register-header {
        color: #198754;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #a3cfbb;
        padding: 10px;
    }

    .btn-green {
        background: linear-gradient(45deg, #198754 0%, #a3cfbb 100%);
        border: none;
        border-radius: 25px;
        padding: 10px;
        color: white;
        font-weight: bold;
        width: 100%;
        margin-top: 15px;
    }
</style>

<div class="overlay"></div>
<div class="container my-5" dir="rtl">
    <div class="text-center mb-4">
        <h1 class="fw-bold" style="color: #198754;">🌱 הצטרפות כלקוח חדש 🌱</h1>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center shadow-sm mx-auto mb-4" style="max-width: 500px;">
            @ViewBag.Error
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="access-card text-center">
                <span style="font-size: 2.5rem;">📝</span>
                <h3 class="register-header">לקוחות חדשים (הרשמה)</h3>
                <p class="text-muted small">הקלידו פרטים חד-פעמיים כדי להירשם במסד הנתונים של החנות</p>

                <form asp-action="Register" method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold text-secondary">שם מלא</label>
                        <input type="text" name="customerName" class="form-control" placeholder="לדוגמה: ישראל ישראלי" required />
                    </div>
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold text-secondary">תעודת זהות</label>
                        <input type="text" name="customerID" class="form-control" placeholder="לדוגמה: 123456789" required />
                    </div>
                    <button type="submit" class="btn btn-green">הרשמה ושמירה במערכת ✨</button>
                </form>
            </div>
        </div>
    </div>
</div>