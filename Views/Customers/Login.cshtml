@{
    ViewData["Title"] = "Customer Login";
}

<style>
    /* תמונת רקע של פרחים ורודים לכל המסך */
    body {
        background: url('https://images.unsplash.com/photo-1490750967868-58cb75069ed6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80') no-repeat center center fixed;
        background-size: cover;
    }

    /* שכבה כהה עדינה על הרקע כדי שהטקסט יהיה קריא */
    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.3); /* לבן שקוף */
        z-index: -1;
    }

    /* עיצוב כרטיס ההתחברות */
    .login-card {
        background-color: rgba(255, 255, 255, 0.95); /* לבן כמעט אטום */
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        padding: 40px;
        max-width: 450px;
        margin: 80px auto; /* מירכוז */
        text-align: center;
        border: 2px solid #ffdde1;
    }

    .login-header {
        color: #d63384; /* ורוד כהה */
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #ffb7b2;
        padding: 12px;
    }

        .form-control:focus {
            border-color: #d63384;
            box-shadow: 0 0 5px rgba(214, 51, 132, 0.5);
        }

    .btn-pink {
        background: linear-gradient(45deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
        border: none;
        border-radius: 25px;
        padding: 12px;
        color: white;
        font-weight: bold;
        font-size: 1.1em;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 20px;
    }

        .btn-pink:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 154, 158, 0.4);
            color: white;
        }

    .icon-flower {
        font-size: 3rem;
        margin-bottom: 10px;
        display: block;
    }
</style>

<div class="overlay"></div>

<div class="container">
    <div class="login-card">
        <span class="icon-flower">🌸</span>
        <h2 class="login-header">Welcome to LyaShop</h2>
        <p class="text-muted">הכנס פרטים כדי להתחיל לעצב את הזר שלך</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3 text-start">
                <label class="form-label fw-bold text-secondary">שם מלא</label>
                <input type="text" name="customerName" class="form-control" placeholder="לדוגמה: ליאה כהן" required />
            </div>

            <div class="mb-3 text-start">
                <label class="form-label fw-bold text-secondary">תעודת זהות</label>
                <input type="text" name="customerID" class="form-control" placeholder="לדוגמה: 123456789" required />
            </div>

            <button type="submit" class="btn btn-pink">כניסה לחנות 💐</button>
        </form>

        <div class="mt-4">
            <a asp-controller="Admin" asp-action="Login" class="text-muted small" style="text-decoration: none;">
                ניהול מערכת (למנהלים בלבד)
            </a>
        </div>
    </div>
</div>