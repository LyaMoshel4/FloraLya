@{
    ViewData["Title"] = "התחברות לקוחות";
}

<style>
    body {
        background: url('https://images.unsplash.com/photo-1490750967868-58cb75069ed6?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80') no-repeat center center fixed;
        background-size: cover;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.3);
        z-index: -1;
    }

    .access-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        padding: 30px;
        border: 2px solid #ffdde1;
    }

    .login-header {
        color: #d63384;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #ffb7b2;
        padding: 10px;
    }

        .form-control:focus {
            border-color: #d63384;
            box-shadow: 0 0 5px rgba(214, 51, 132, 0.5);
        }

    .btn-pink {
        background: linear-gradient(45deg, #ff9a9e 0%, #fecfef 99%);
        border: none;
        border-radius: 25px;
        padding: 10px;
        color: white;
        font-weight: bold;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 15px;
    }

        .btn-pink:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 154, 158, 0.4);
            color: white;
        }
</style>

<div class="overlay"></div>

<div class="container my-5" dir="rtl">
    <div class="text-center mb-4">
        <h1 class="fw-bold" style="color: #d63384;">🌸 כניסה לחשבון קיים 🌸</h1>
        <p class="text-dark fw-bold">אנא הזן את פרטיך כדי להמשיך בעיצוב ובביצוע ההזמנה</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center shadow-sm mx-auto mb-4" style="max-width: 500px;" role="alert">
            @ViewBag.Error
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="access-card text-center">
                <span style="font-size: 2.5rem;">🔑</span>
                <h3 class="login-header">לקוחות רשומים (התחברות)</h3>
                <p class="text-muted small">רשומים כבר במערכת? הכניסו פרטים כדי לצפות בהזמנות קודמות ולהמשיך</p>

                <form asp-action="Login" method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold text-secondary">שם מלא / אימייל מנהל</label>
                        <input type="text" name="customerName" class="form-control" placeholder="הכנס שם מלא" required />
                    </div>
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold text-secondary">תעודת זהות / סיסמת מנהל</label>
                        <input type="password" name="customerID" class="form-control" placeholder="הכנס תעודת זהות" required />
                    </div>
                    <button type="submit" class="btn btn-pink">התחברות לחשבון 🛍️</button>
                </form>
            </div>
        </div>
    </div>
</div>