@model IEnumerable<LyaShop.Models.Order>

@{
    ViewData["Title"] = "הפרופיל שלי";
}

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="card shadow-sm p-4 mb-5 bg-white rounded border-0" style="border-right: 5px solid #007bff !important;">
        <h2 style="font-weight: 700;">שלום, @ViewBag.CustomerName! 👋</h2>
        <p class="text-muted mb-0">ברוך הבא לאזור האישי שלך. כאן תוכל לצפות בהיסטוריית ההזמנות המלאה שלך בחנות.</p>
    </div>

    <h3 class="mb-4" style="font-weight: 600;">היסטוריית ההזמנות שלי</h3>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info p-5 text-center shadow-sm">
            <h4 class="alert-heading">עדיין לא ביצעת הזמנות באתר 🌸</h4>
            <p class="mb-4">כל הזרים והפרחים שתזמין בעתיד יופיעו כאן בצורה מסודרת.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2">להזמנת הזר הראשון שלך שופינג!</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover align-middle mb-0 bg-white">
                <thead class="table-dark text-center">
                    <tr>
                        <th scope="col" style="width: 15%;">מספר הזמנה</th>
                        <th scope="col" style="width: 20%;">תאריך ושעה</th>
                        <th scope="col" style="width: 35%;">פירוט הפריטים שהוזמנו</th>
                        <th scope="col" style="width: 15%;">סכום כולל</th>
                        <th scope="col" style="width: 15%;">סטטוס הזמנה</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold text-primary">#@order.Id</span>
                            </td>
                            <td class="text-muted">
                                @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-end px-4">
                                @order.ItemsSummary
                            </td>
                            <td class="fw-bold text-success">
                                ₪@order.TotalPrice
                            </td>
                            <td>
                                @if (order.Status == "הושלמה")
                                {
                                    <span class="badge bg-success p-2 px-3 rounded-pill">הושלמה</span>
                                }
                                else if (order.Status == "בטיפול" || order.Status == "נשלח")
                                {
                                    <span class="badge bg-warning text-dark p-2 px-3 rounded-pill">@order.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary p-2 px-3 rounded-pill">@order.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>