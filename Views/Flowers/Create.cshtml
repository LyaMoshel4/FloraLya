@model LyaFlowerShop.Models.Flower

<div class="container mt-4">
    <h2>Add New Flower 🌸</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Flower Name</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price (₪)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                </div>
                <div class="mb-3">
                    <label asp-for="StockQnty" class="form-label">Quantity</label>
                    <input asp-for="StockQnty" class="form-control" type="number" />
                </div>

                @* שדה התמונה שהיה חסר *@
                <div class="mb-3">
                    <label asp-for="ImagePath" class="form-label">Image Filename</label>
                    <input asp-for="ImagePath" class="form-control" placeholder="e.g., rose.jpg" />
                    <small class="text-muted">Enter the filename of the image in your wwwroot/images folder.</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Flower</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>