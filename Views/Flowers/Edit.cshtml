@model LyaShop.Models.Flower

<div class="container mt-4">
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">Edit Flower: @Model.Name 🌿</h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-7">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        @* שדה נסתר ל-ID - קריטי לעדכון תקין בבסיס הנתונים *@
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Flower Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">Price (₪)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQnty" class="form-label fw-bold">Quantity in Stock</label>
                                <input asp-for="StockQnty" class="form-control" type="number" />
                                <span asp-validation-for="StockQnty" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImagePath" class="form-label fw-bold">Image Filename</label>
                            <input asp-for="ImagePath" class="form-control" placeholder="e.g., lily.png" />
                            <small class="text-muted">Update filename if you changed the image in wwwroot/images.</small>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-warning px-4">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">Back to List</a>
                        </div>
                    </form>
                </div>

                @* תצוגה מקדימה של התמונה הקיימת *@
                <div class="col-md-5 text-center d-flex flex-column align-items-center justify-content-center bg-light rounded">
                    <h6 class="text-muted mb-3">Current Image</h6>
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <img src="/images/@Model.ImagePath" alt="@Model.Name" class="img-fluid rounded shadow" style="max-height: 250px; object-fit: cover;"
                             onerror="this.src='https://via.placeholder.com/200?text=No+Image+Found'" />
                    }
                    else
                    {
                        <div class="p-5 border bg-white text-muted">No Image Assigned</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}