@model LyaFlowerShop.Models.Flower

<div class="container mt-4">
    <h2>Edit Flower: @Model.Name 🌿</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @* חשוב מאוד: שומר את ה-ID של הפרח כדי שהקונטרולר יזהה אותו *@
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Flower Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price (₪)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StockQnty" class="form-label">Quantity in Stock</label>
                    <input asp-for="StockQnty" class="form-control" type="number" />
                    <span asp-validation-for="StockQnty" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImagePath" class="form-label">Image Filename</label>
                    <input asp-for="ImagePath" class="form-control" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>