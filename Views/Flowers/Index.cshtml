@model IEnumerable<LyaShop.Models.Flower>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5" style="color: #d63384;">🌷 ניהול מלאי פרחים</h1>
        <a asp-action="Create" class="btn btn-success shadow-sm" style="border-radius: 20px;">
            <i class="bi bi-plus-circle"></i> הוספת פרח חדש
        </a>
    </div>

    <div class="card shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 120px;">תמונה</th>
                        <th>שם הפרח</th>
                        <th>צבע</th>
                        <th>מחיר</th>
                        <th>מלאי</th>
                        <th>פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    @* שימוש ב-CSS Filter כדי לשנות את צבע הפרח מבלי להעלות תמונה חדשה *@
                                    <img src="@item.ImageUrl" alt="@item.Name"
                                         style="width:70px; height:70px; object-fit:contain; border-radius:10px; background-color: #f8f9fa; border: 1px solid #eee;
                                                filter: hue-rotate(@(item.HueRotation)deg);" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center rounded mx-auto" style="width:70px; height:70px;">
                                        <i class="bi bi-image text-muted" style="font-size: 1.5rem;"></i>
                                    </div>
                                }
                            </td>
                            <td><strong style="color: #333;">@item.Name</strong></td>
                            <td>
                                <span class="badge rounded-pill shadow-sm" style="background-color: #f1f1f1; color: #333; padding: 8px 15px;">
                                    @item.Color
                                </span>
                            </td>
                            <td class="fw-bold text-success">₪@item.Price</td>
                            <td>
                                <span class="badge @(item.StockQnty > 5 ? "bg-info" : "bg-warning text-dark")">
                                    @item.StockQnty
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="עריכה">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="מחיקה">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* אייקונים *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    body {
        background-color: #fdfdfd;
    }

    .table thead th {
        border: none;
        font-weight: 500;
    }

    .btn-group .btn {
        margin: 0 2px;
        border-radius: 8px !important;
    }
</style>