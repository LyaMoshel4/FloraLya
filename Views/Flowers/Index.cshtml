@model IEnumerable<LyaShop.Models.Flower>

@{
    ViewData["Title"] = "ניהול פרחים - FloraLya";
}

<div class="container mt-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2b4a36; font-family: 'Playfair Display', serif;">ניהול מלאי הפרחים 🌷</h2>
        <span class="badge bg-light text-dark border p-2 fs-6">סה"כ בקטלוג: @Model.Count() סוגי פרחים</span>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark" style="background-color: #2b4a36 !important; border-color: #2b4a36;">
                    <tr>
                        <th scope="col" class="py-3">תמונה</th>
                        <th scope="col" class="py-3">שם הפרח</th>
                        <th scope="col" class="py-3">צבע</th>
                        <th scope="col" class="py-3">מחיר</th>
                        <th scope="col" class="py-3">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @{
                                    // נבדוק איזה שדה מכיל את נתיב התמונה (ImageUrl או ImagePath)
                                    var imgPath = !string.IsNullOrEmpty(item.ImageUrl) ? item.ImageUrl : item.ImagePath;

                                    if (!string.IsNullOrEmpty(imgPath))
                                    {
                                        <img src="@imgPath" class="rounded-3 shadow-sm border" style="width: 60px; height: 60px; object-fit: cover; filter: hue-rotate(@(item.HueRotation)deg);" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="bg-light text-muted rounded-3 border mx-auto d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; font-size: 0.8rem;">אין תמונה</div>
                                    }
                                }
                            </td>
                            <td class="fw-bold text-secondary fs-5">
                                @item.Name
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">@item.Color</span>
                            </td>
                            <td class="fw-bold text-success fs-5">
                                ₪@item.Price
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-3 px-3">
                                        ✏️ ערוך
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-3 px-3" onclick="return confirm('האם אתה בטוח שברצונך למחוק פרח זה?');">
                                        🗑️ מחק
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>