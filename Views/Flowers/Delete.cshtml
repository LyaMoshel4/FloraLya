@model LyaShop.Models.Flower

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm" style="border-radius: 15px;">
                <div class="card-body text-center p-5">
                    <h1 class="text-danger mb-4"><i class="bi bi-exclamation-triangle"></i></h1>
                    <h2 class="mb-3">בטוח שברצונך למחוק?</h2>
                    <p class="text-muted">אתה עומד למחוק את <strong>@Model.Name</strong> מהמלאי. פעולה זו לצמיתות.</p>

                    <div class="my-4">
                        <img src="@Model.ImageUrl" style="width: 100px; height: 100px; object-fit: contain; filter: hue-rotate(@(Model.HueRotation)deg);" />
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg px-5 mx-2" style="border-radius: 30px;">כן, מחק</button>
                        <a asp-action="Index" class="btn btn-light btn-lg px-5 mx-2" style="border-radius: 30px;">ביטול</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>