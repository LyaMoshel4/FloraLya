@model LyaShop.Models.Flower

<div class="container mt-4">
    <h2 class="text-danger">Delete Flower 🗑️</h2>
    <h3>Are you sure you want to delete this?</h3>
    <hr />

    <div class="card col-md-6 border-danger shadow-sm">
        <div class="card-body">
            <h4 class="card-title fw-bold">@Model.Name</h4>
            <p class="card-text"><strong>Description:</strong> @Model.Description</p>
            <p class="card-text"><strong>Price:</strong> @Model.Price ₪</p>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="mt-3 text-center">
                    <img src="/images/@Model.ImagePath" alt="@Model.Name" class="img-thumbnail" style="max-height: 200px;"
                         onerror="this.style.display='none'" />
                </div>
            }
        </div>
    </div>

    <div class="mt-4">
        <form asp-action="DeleteConfirmed" method="post">
            @* שימי לב: שינינו את ה-Action ל-DeleteConfirmed אם זה השם בקונטרולר שלך *@
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger px-4">Yes, Delete it</button>
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </form>
    </div>
</div>