@model LyaFlowerShop.Models.Flower

<div class="container mt-4">
    <h2 class="text-danger">Delete Flower 🗑️</h2>
    <h3>Are you sure you want to delete this?</h3>
    <hr />

    <div class="card col-md-6 border-danger">
        <div class="card-body">
            <h4 class="card-title">@Model.Name</h4>
            <p class="card-text"><strong>Description:</strong> @Model.Description</p>
            <p class="card-text"><strong>Price:</strong> @Model.Price ₪</p>
        </div>
    </div>

    <div class="mt-4">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete it</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>