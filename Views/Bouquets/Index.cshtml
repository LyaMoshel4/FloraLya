@model IEnumerable<LyaShop.Models.Bouquet>

@{
    ViewData["Title"] = "ניהול זרים - FloraLya";
}

<div class="container mt-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2b4a36; font-family: 'Playfair Display', serif;">רשימת זרים שנוצרו 🌸</h2>
        <span class="badge bg-light text-dark border p-2 fs-6">סה"כ במערכת: @Model.Count() זרים</span>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark" style="background-color: #2b4a36 !important; border-color: #2b4a36;">
                    <tr>
                        <th scope="col" class="py-3">שם הזר ופרטי לקוח</th>
                        <th scope="col" class="py-3">תמונה / תצוגה</th>
                        <th scope="col" class="py-3">מחיר</th>
                        <th scope="col" class="py-3">פעולות</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary fs-5">
                                @item.Name
                            </td>

                            <td>
                                <div class="rounded-3 shadow-sm border bouquet-box-holder mx-auto">
                                    @if (!string.IsNullOrEmpty(item.BouquetDesignHtml))
                                    {
                                        <div class="bouquet-scale-wrapper">
                                            @Html.Raw(item.BouquetDesignHtml)
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-white-50 small d-flex h-100 align-items-center justify-content-center">אין תצוגה</div>
                                    }
                                </div>
                            </td>

                            <td class="fw-bold text-success fs-5">
                                ₪@item.Price
                            </td>

                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-link text-dark p-0 border-0 fs-4" type="button" id="actions-@item.Id" data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration: none; line-height: 1;">
                                        ⋮
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end text-right shadow-sm border-0 rounded-3" aria-labelledby="actions-@item.Id" style="min-width: 160px; direction: rtl; text-align: right;">
                                        <li>
                                            <button type="button" class="dropdown-menu-item dropdown-item py-2"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#detailsModal-@item.Id">
                                                🔍 פרטי הזמנה
                                            </button>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item py-2 text-danger fw-bold" asp-controller="Bouquets" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('האם אתה בטוח שברצונך למחוק זר זה?');">
                                                🗑️ מחיקת זר
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @foreach (var item in Model)
    {
        <div class="modal fade" id="detailsModal-@item.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header bg-light border-0 py-3 px-4">
                        <h5 class="modal-title fw-bold" style="color: #2b4a36;">📋 פרטי משלוח והזמנה</h5>
                        <button type="button" class="btn-close m-0 ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 text-start" style="direction: rtl; text-align: right;">
                        <div class="mb-3 border-bottom pb-2">
                            <span class="text-muted small d-block">💐 שם הזר והמזמין</span>
                            <strong class="fs-5 text-dark">@item.Name</strong>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <span class="text-muted small d-block">📍 כתובת למשלוח</span>
                            <strong class="fs-6 text-success">
                                @(string.IsNullOrEmpty(item.ShippingAddress) ? "לא הוכנסה כתובת (הזמנה ישנה)" : item.ShippingAddress)
                            </strong>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <span class="text-muted small d-block">📞 טלפון ליצירת קשר</span>
                            <strong class="fs-6 text-primary" style="direction: ltr; display: inline-block;">
                                @(string.IsNullOrEmpty(item.CustomerPhone) ? "אין מספר טלפון" : item.CustomerPhone)
                            </strong>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <span class="text-muted small d-block">📅 תאריך ושעת הזמנה</span>
                            <strong class="fs-6 text-dark">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small d-block">💰 סה"כ לתשלום</span>
                            <strong class="fs-4 text-danger">₪@item.Price</strong>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light py-2">
                        <button type="button" class="btn text-white fw-bold px-4" style="background-color: #2b4a36; border-radius: 50px;" data-bs-dismiss="modal">סגור חלונית</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bouquet-box-holder {
        width: 140px !important;
        height: 140px !important;
        background: #080808 !important;
        position: relative !important;
        overflow: hidden !important;
    }

    .bouquet-scale-wrapper {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 600px !important;
        height: 600px !important;
        transform: scale(0.2333) !important;
        transform-origin: top left !important;
        pointer-events: none !important;
    }

        .bouquet-scale-wrapper > .bouquet-saved-canvas {
            width: 600px !important;
            height: 600px !important;
        }

    .table th {
        font-weight: 500;
        letter-spacing: 0.5px;
    }

    .dropdown-item:hover {
        background-color: #f8f9fa;
        color: #2b4a36 !important;
    }
</style>