<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-0 position-relative bg-light overflow-hidden d-flex justify-content-center" 
                     style="height: 400px;">
                    
                    <div class="position-absolute" 
                         style="bottom: 20px; width: 220px; height: 320px; background-color: #d7bfa6; 
                                clip-path: polygon(0 0, 100% 0, 50% 100%); z-index: 1;">
                    </div>

					<div class="position-absolute w-1000 h-100" style="z-index: 2; pointer-events: none;">
						<div style="transform: scale(1.1) translateX(-75px) translateY(-50px); 
                width: 100%; height: 100%; 
                display: flex; justify-content: center; align-items: center;">

							<div class="bouquet-spread-container">
								@if (!string.IsNullOrEmpty(item.BouquetDesignHtml))
								{
								@Html.Raw(item.BouquetDesignHtml)
								}
							</div>
						</div>
					</div>

					<style>
						.bouquet-spread-container {
						position: relative;
						width: 0;
						height: 0;
						}

						.bouquet-spread-container img {
						position: absolute !important;
						left: 0 !important;
						top: 0 !important;
						transform-origin: bottom center;
						}

						/* Fan out logic - adjusted to be more compact and fit the cone opening */
						.bouquet-spread-container img:nth-child(odd) {
						transform: translate(-50%, -100%) rotate(-15deg) translateX(-35px);
						}
						.bouquet-spread-container img:nth-child(even) {
						transform: translate(-50%, -100%) rotate(15deg) translateX(35px);
						}
						.bouquet-spread-container img:nth-child(3n) {
						transform: translate(-50%, -100%) rotate(-5deg) translateY(-5px);
						}
						.bouquet-spread-container img:nth-child(4n) {
						transform: translate(-50%, -100%) rotate(10deg) translateX(20px) translateY(-10px);
						}
						.bouquet-spread-container img:nth-child(5n) {
						transform: translate(-50%, -100%) rotate(0deg) translateY(-30px);
						}
					
					</style>
                    <div class="position-absolute start-50 translate-middle-x" 
                         style="bottom: 100px; z-index: 3; font-size: 3rem;">
                        🎀
                    </div>
                </div>
                
                <div class="card-footer bg-white text-center py-3">
                    <h5 class="card-title fw-bold">@item.Name</h5>
                    <h4 class="text-success fw-bold">₪@item.Price</h4>
                    <div class="mt-3 btn-group w-100">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-dark">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>