@model IEnumerable<LyaShop.Models.Bouquet>

<div class="container mt-5">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                    
                    @* מסגרת התמונה - הגדלנו את הגובה ל-300px *@
                    <div class="card-img-top bg-light" style="height: 300px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                        
                        @if (!string.IsNullOrEmpty(item.BouquetDesignHtml))
                        {
                            @* שינינו את ה-scale ל-0.6 כדי שיהיה גדול יותר, והוספנו מרכוז *@
                            <div class="bouquet-preview-container" style="transform: scale(0.65); transform-origin: center; width: 500px; height: 500px; position: absolute; display: flex; align-items: center; justify-content: center;">
                                @Html.Raw(item.BouquetDesignHtml)
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted" style="opacity: 0.4;">
                                <p>No design saved</p>
                                <span style="font-size: 60px;">💐</span>
                            </div>
                        }
                    </div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4 class="card-title mb-0 fw-bold">@item.Name</h4>
                            <span class="badge bg-warning text-dark">₪@item.Price</span>
                        </div>
                        
                        <div class="btn-group w-100 mt-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this bouquet?');" style="display:contents;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* תיקונים קריטיים למרכוז האלמנטים בתוך הגלריה */
    .bouquet-preview-container .bouquet-base {
        left: 50% !important;
        transform: translateX(-50%) !important;
        bottom: 50px !important;
    }

    .bouquet-preview-container img.flower-instance {
        /* מבטיח שהפרחים יישארו במיקומם היחסי למרכז התיבה */
        max-width: none !important;
    }

    .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>