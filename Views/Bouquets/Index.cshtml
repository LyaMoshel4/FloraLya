@model IEnumerable<LyaShop.Models.Bouquet>

<style>
    /* הריבוע השחור בטבלה */
    .bouquet-preview-box {
        width: 150px;
        height: 150px;
        background-color: #080808;
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        margin: 0 auto;
        border: 1px solid #333;
    }

    /* הקוד שדואג שיראו את כל הזר במרכז הריבוע */
    .bouquet-content-scaler {
        position: absolute;
        /* מציב את נקודת האמצע של הזר במרכז הריבוע */
        top: 50%;
        left: 50%;
        /* מקטין את הזר ל-25% מהגודל המקורי וממרכז אותו */
        transform: translate(-50%, -50%) scale(0.25);
        transform-origin: center center;
        white-space: nowrap;
    }

        /* תיקון לתמונות בתוך הזר כדי שלא ימרחו */
        .bouquet-content-scaler img {
            max-width: none !important;
        }

    .table td {
        vertical-align: middle;
    }
</style>

<div class="container mt-5 text-end" dir="rtl">
    <h2 class="text-center mb-4" style="font-family: serif; color: #2b4a36;">רשימת זרים שנוצרו</h2>

    <table class="table table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th class="text-center">שם הזר</th>
                <th class="text-center">תמונה</th>
                <th class="text-center">מחיר</th>
                <th class="text-center">פעולות</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center fw-bold">@item.Name</td>
                    <td>
                        <div class="bouquet-preview-box">
                            <div class="bouquet-content-scaler">
                                @Html.Raw(item.BouquetDesignHtml)
                            </div>
                        </div>
                    </td>
                    <td class="text-center text-success fw-bold">₪@item.Price</td>
                    <td class="text-center">
                        <div class="btn-group gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill">עריכה</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-pill">מחיקה</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>