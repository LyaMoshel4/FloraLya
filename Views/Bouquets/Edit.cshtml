@model LyaShop.Models.Bouquet

@{
    ViewData["Title"] = "Edit Bouquet";
    var flowersList = ViewBag.Flowers as List<LyaShop.Models.Flower>;
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h1 class="display-4 text-primary fw-bold">Edit Your Bouquet ✏️</h1>
        <p class="lead text-muted">Modify existing design, add or remove flowers.</p>
    </div>

    <div class="row">
        @* --- צד שמאל: בחירת פרחים --- *@
        <div class="col-md-3">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-warning text-dark fw-bold">
                    Choose Flowers 🌸
                </div>
                <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                    <div class="row g-2">
                        @if (flowersList != null)
                        {
                            foreach (var flower in flowersList)
                            {
                                <div class="col-6 text-center">
                                    @* תיקון: שימוש ב-ImagePath *@
                                    <div class="flower-item border rounded p-2 pointer" 
                                         onclick="addFlower('@flower.ImagePath', '@flower.Price')">
                                        
                                        @* תיקון: שימוש ב-ImagePath *@
                                        <img src="@flower.ImagePath" class="img-fluid mb-1" style="height: 60px; object-fit: contain;">
                                        
                                        <div style="font-size: 0.8rem;">@flower.Name</div>
                                        <div class="fw-bold text-success">₪@flower.Price</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Back to Gallery</a>
        </div>

        @* --- צד ימין: משטח העבודה + טופס שמירה --- *@
        <div class="col-md-9">
            <form asp-action="Edit" id="designForm" onsubmit="saveDesign()">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" id="BouquetDesignHtml" name="BouquetDesignHtml" />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Bouquet Name:</label>
                    <input asp-for="Name" class="form-control" placeholder="E.g., Summer Vibes" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="card shadow-sm border-0 mb-3 position-relative bg-light" style="height: 500px; overflow: hidden;">
                    <img src="/images/wrapping_paper.png" class="position-absolute top-50 start-50 translate-middle" 
                         style="height: 90%; opacity: 0.9; z-index: 1;" alt="Wrapping">
                    
                    <img src="/images/ribbon_pink.png" class="position-absolute start-50 translate-middle-x" 
                         style="bottom: 100px; width: 100px; z-index: 20;" alt="Ribbon">

                    <div id="bouquetCanvas" class="w-100 h-100 position-relative" style="z-index: 10;">
                        @Html.Raw(Model.BouquetDesignHtml)
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm border">
                    <div>
                        <span class="h4">Total Price: </span>
                        <span class="h3 text-success fw-bold">₪<span id="totalPriceDisplay">@Model.Price</span></span>
                        <input type="hidden" id="Price" name="Price" value="@Model.Price" />
                    </div>
                    <button type="submit" class="btn btn-success btn-lg px-5">Save Changes 💾</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // המרת המחיר למספר
        let initialPrice = "@Model.Price";
        let currentPrice = parseFloat(initialPrice);
        if (isNaN(currentPrice)) currentPrice = 0;

        // 1. פונקציה שרצה כשהדף עולה כדי "להחיות" את הפרחים הקיימים
        document.addEventListener("DOMContentLoaded", function() {
            // מוצא את כל הפרחים שכבר היו בזר
            const existingFlowers = document.querySelectorAll('.flower-on-canvas');
            
            existingFlowers.forEach(flowerDiv => {
                // מחפש את כפתור המחיקה שלהם (אם קיים)
                const closeBtn = flowerDiv.querySelector('.remove-btn');
                
                // מנסה לקרוא את המחיר שהיה שמור בתוך ה-HTML
                let priceAttr = flowerDiv.getAttribute('data-price');
                let price = parseFloat(priceAttr);
                if (isNaN(price)) price = 0;
                
                // מחבר מחדש את אירוע המחיקה
                if(closeBtn) {
                    closeBtn.onclick = function() {
                        flowerDiv.remove();
                        updatePrice(-price);
                    };
                }
            });
        });

        // 2. הוספת פרח חדש
        function addFlower(imgUrl, price) {
            const canvas = document.getElementById("bouquetCanvas");
            const priceVal = parseFloat(price);

            // יצירת אלמנט לפרח החדש
            const div = document.createElement("div");
            div.className = "flower-on-canvas position-absolute";
            // מיקום רנדומלי
            div.style.left = (50 + (Math.random() * 20 - 10)) + "%"; 
            div.style.top = (40 + (Math.random() * 20 - 10)) + "%";
            div.style.transform = "translate(-50%, -50%)";
            div.setAttribute('data-price', priceVal);

            // HTML פנימי
            div.innerHTML = `
                <div class="position-relative">
                    <img src="${imgUrl}" style="height: 100px; filter: drop-shadow(2px 2px 2px rgba(0,0,0,0.2));">
                    <button type="button" class="remove-btn btn btn-danger btn-sm rounded-circle position-absolute top-0 start-100 translate-middle p-0" 
                            style="width: 20px; height: 20px; line-height: 1; font-size: 12px;">X</button>
                </div>
            `;

            canvas.appendChild(div);

            // הגדרת אירוע מחיקה לפרח החדש
            div.querySelector(".remove-btn").onclick = function() {
                div.remove();
                updatePrice(-priceVal);
            };

            updatePrice(priceVal);
        }

        // 3. עדכון מחיר
        function updatePrice(amount) {
            currentPrice += amount;
            if (currentPrice < 0) currentPrice = 0;
            
            document.getElementById("totalPriceDisplay").innerText = currentPrice.toFixed(2);
            document.getElementById("Price").value = currentPrice;
        }

        // 4. שמירה
        function saveDesign() {
            const canvas = document.getElementById("bouquetCanvas");
            
            // משכפל את הקנבס כדי לנקות ממנו את כפתורי המחיקה לפני השמירה
            const clone = canvas.cloneNode(true);
            const buttons = clone.querySelectorAll(".remove-btn");
            buttons.forEach(btn => btn.remove());

            // שמירת ה-HTML הנקי
            document.getElementById("BouquetDesignHtml").value = clone.innerHTML;
        }
    </script>

    <style>
        .flower-item:hover {
            background-color: #f8f9fa;
            border-color: #0d6efd !important;
            transform: scale(1.05);
            transition: all 0.2s;
        }
        .flower-on-canvas {
            cursor: pointer;
            transition: transform 0.2s;
        }
        .flower-on-canvas:hover {
            z-index: 100;
            transform: translate(-50%, -50%) scale(1.1) !important;
        }
    </style>
}