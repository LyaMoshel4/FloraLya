@model LyaShop.Models.Bouquet

@{
    ViewData["Title"] = "עריכת זר";
}

<div class="container mt-4" dir="rtl">
    <h2 class="mb-4 text-primary text-center">💐 עריכת הזר היוקרתי שלך</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Edit" method="post" id="bouquetForm">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BouquetDesignHtml" id="designHtmlInput" />

                <div class="card shadow-sm p-4 border-0 text-end">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">שם הזר</label>
                        <input asp-for="Name" class="form-control text-end" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">הוספת פרחים לזר הקיים</label>
                        <div id="flowerControls" class="list-group mb-2">
                            @if (ViewBag.Flowers != null)
                            {
                                foreach (var flower in (IEnumerable<LyaShop.Models.Flower>)ViewBag.Flowers)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 bg-light mb-2 rounded">
                                        <div class="input-group input-group-sm" style="width: 120px;">
                                            <button type="button" class="btn btn-outline-secondary btn-plus" data-id="@flower.Id">+</button>
                                            <input type="number" name="flower_@flower.Id" class="form-control text-center flower-qty"
                                                   value="0" min="0"
                                                   data-id="@flower.Id"
                                                   data-name="@flower.Name"
                                                   data-price="@flower.Price"
                                                   data-img="@flower.ImageUrl"
                                                   data-hue="@flower.HueRotation" readonly>
                                            <button type="button" class="btn btn-outline-secondary btn-minus" data-id="@flower.Id">-</button>
                                        </div>
                                        <span class="fw-bold">@flower.Name <small class="text-muted">(₪@flower.Price)</small></span>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-bold">מחיר כולל (₪)</label>
                        <input asp-for="Price" id="totalPrice" class="form-control fw-bold bg-warning text-dark text-center" type="number" step="0.01" readonly />
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm fw-bold">שמור שינויים</button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2 text-secondary">ביטול וחזרה לרשימה</a>
                </div>
            </form>
        </div>

        <div class="col-md-7">
            <div class="card shadow shadow-lg h-100 bg-white" style="border: 1px solid #eee; position: relative; overflow: hidden; min-height: 600px;">
                <div id="bouquetCanvas" class="card-body p-0" style="position: relative; width: 100%; height: 600px; background: #080808; overflow: hidden;">
                    <div id="originalBouquetContent">
                        @Html.Raw(Model.BouquetDesignHtml)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            const basePrice = parseFloat('@Model.Price') || 0;
            $('#totalPrice').val(basePrice.toFixed(2));

            $('.btn-plus').click(function () {
                var input = $(this).siblings('.flower-qty');
                input.val(parseInt(input.val()) + 1);
                updateBouquet();
            });

            $('.btn-minus').click(function () {
                var input = $(this).siblings('.flower-qty');
                if (parseInt(input.val()) > 0) {
                    input.val(parseInt(input.val()) - 1);
                    updateBouquet();
                }
            });

            function updateBouquet() {
                var canvas = $('#bouquetCanvas');
                canvas.find('.new-flower-head, #newSvgLayer').remove();

                var addedPrice = 0;
                var newFlowers = [];

                $('.flower-qty').each(function () {
                    var qty = parseInt($(this).val());
                    if (qty > 0) {
                        addedPrice += (qty * parseFloat($(this).data('price')));
                        for (var i = 0; i < qty; i++) {
                            newFlowers.push({
                                img: $(this).data('img'),
                                hue: $(this).data('hue')
                            });
                        }
                    }
                });

                $('#totalPrice').val((basePrice + addedPrice).toFixed(2));

                if (newFlowers.length > 0) {
                    // תיקון המיקום: הזזתי את ה-Y למטה ואת ה-X מעט ימינה שיתאים לסרט
                    var ribbonX = (canvas.width() / 2) + 5;
                    var ribbonY = 480; // הנמכתי מ-435 ל-480 כדי שישב על הסרט

                    var svgHtml = `<svg id="newSvgLayer" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 50; pointer-events: none;">`;

                    newFlowers.forEach(function (flower) {
                        var angleDeg = (Math.random() * 80) - 40;
                        var angleRad = angleDeg * Math.PI / 180;
                        var radius = 140 + Math.random() * 80; // הגבעולים יגיעו גבוה יותר

                        var fx = ribbonX + Math.sin(angleRad) * radius;
                        var fy = ribbonY - Math.cos(angleRad) * radius;

                        svgHtml += `<path d="M ${fx} ${fy} Q ${ribbonX} ${ribbonY - 50} ${ribbonX} ${ribbonY}"
                                   fill="none" stroke="#527a48" stroke-width="6" stroke-linecap="round" />`;

                        var headSize = 85;
                        var headStyle = `position: absolute; width: ${headSize}px; left: ${fx - (headSize/2)}px; top: ${fy - (headSize/2)}px; z-index: 100; filter: hue-rotate(${flower.hue}deg) drop-shadow(2px 4px 8px rgba(0,0,0,0.5)); pointer-events: none;`;
                        canvas.append(`<img src="${flower.img}" class="new-flower-head" style="${headStyle}">`);
                    });

                    svgHtml += `</svg>`;
                    canvas.append(svgHtml);
                }
            }

            $('#bouquetForm').on('submit', function() {
                $('#designHtmlInput').val($('#bouquetCanvas').html());
            });
        });
    </script>
}