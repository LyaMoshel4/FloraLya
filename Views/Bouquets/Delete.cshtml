@model LyaShop.Models.Bouquet

@{
    ViewData["Title"] = "מחיקת זר";
}

<div class="container mt-5 text-center" dir="rtl">
    <h2 class="text-danger fw-bold">🗑️ האם את בטוחה שברצונך למחוק את הזר הזה?</h2>
    <p class="text-muted">לא ניתן לבטל פעולה זו לאחר הביצוע.</p>

    <div class="row justify-content-center mt-4">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div style="background: #080808; height: 420px; position: relative; overflow: hidden;">
                    <div style="position: absolute; width: 100%; height: 600px; top: -90px; left: 0; transform: scale(0.85); transform-origin: top center;">
                        @Html.Raw(Model.BouquetDesignHtml)
                    </div>
                </div>

                <div class="card-body bg-light p-4">
                    <h3 class="card-title fw-bold text-primary mb-2">@Model.Name</h3>
                    <p class="fs-4 fw-bold text-dark mb-4">מחיר: ₪@Model.Price</p>

                    <hr>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-3">
                            <button type="submit" class="btn btn-danger btn-lg px-4 shadow-sm fw-bold">כן, מחק את הזר!</button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-4 shadow-sm">ביטול</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>