@model LyaShop.Models.Bouquet

@{
    ViewData["Title"] = "Professional Bouquet Designer";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">💐 Design Your Luxury Bouquet</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Create" method="post">
                <div class="card shadow-sm p-4 border-0">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Bouquet Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Red Romance" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Add Flowers to Bouquet</label>
                        <div id="flowerControls" class="list-group mb-2">
                            @if (ViewBag.Flowers != null)
                            {
                                foreach (var flower in (IEnumerable<LyaShop.Models.Flower>)ViewBag.Flowers)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 bg-light mb-2 rounded">
                                        <span>@flower.Name</span>
                                        <div class="input-group input-group-sm" style="width: 120px;">
                                            <button type="button" class="btn btn-outline-secondary btn-minus" data-id="@flower.Id">-</button>
                                            <input type="number" name="flower_@flower.Id" class="form-control text-center flower-qty"
                                                   value="0" min="0" data-id="@flower.Id" data-name="@flower.Name"
                                                   data-img="@flower.ImagePath" readonly>
                                            <button type="button" class="btn btn-outline-secondary btn-plus" data-id="@flower.Id">+</button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Total Price (₪)</label>
                        <input asp-for="Price" id="totalPrice" class="form-control" type="number" step="0.01" required readonly value="0" />
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">Order This Bouquet</button>
                </div>
                <div id="hiddenFields"></div>
            </form>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm h-100 bg-white" style="border: 1px solid #eee; position: relative; overflow: hidden; min-height: 600px;">
                <div id="bouquetCanvas" class="card-body p-0" style="position: relative; height: 100%; background: #fcfcfc;">

                    <div id="wrappingBack" class="wrapping" style="display:none; position: absolute; bottom: 150px; left: 50%; transform: translateX(-50%); width: 350px; height: 400px; background: #f8d7da; clip-path: polygon(0% 20%, 50% 0%, 100% 20%, 80% 100%, 20% 100%); opacity: 0.6; z-index: 5;"></div>

                    <div id="placeholderText" class="text-center text-muted" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                        <p>Add flowers to build your bouquet!</p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // כפתורי פלוס ומינוס
            $('.btn-plus').click(function () {
                var input = $(this).siblings('.flower-qty');
                input.val(parseInt(input.val()) + 1);
                updateBouquet();
            });

            $('.btn-minus').click(function () {
                var input = $(this).siblings('.flower-qty');
                if (parseInt(input.val()) > 0) {
                    input.val(parseInt(input.val()) - 1);
                    updateBouquet();
                }
            });

            function updateBouquet() {
                var canvas = $('#bouquetCanvas');
                var placeholder = $('#placeholderText');
                var wrapping = $('#wrappingBack');
                var hiddenFields = $('#hiddenFields');

                canvas.find('.flower-instance').remove();
                canvas.find('.bouquet-base').remove();
                hiddenFields.empty();

                var allFlowers = [];
                $('.flower-qty').each(function () {
                    var qty = parseInt($(this).val());
                    var id = $(this).data('id');
                    var name = $(this).data('name').toLowerCase();
                    var img = $(this).data('img');

                    for (var i = 0; i < qty; i++) {
                        allFlowers.push({ id: id, name: name, img: img });
                        // הוספת שדה מוסתר לטופס עבור ה-Controller
                        hiddenFields.append('<input type="hidden" name="selectedFlowers" value="' + id + '">');
                    }
                });

                if (allFlowers.length > 0) {
                    placeholder.hide();
                    wrapping.show();

                    // הוספת סרט וגבעולים בקדמת הזר
                    var baseHtml = '<div class="bouquet-base" style="position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); z-index: 100;">' +
                        '<div style="width: 40px; height: 180px; background: linear-gradient(90deg, #1e3511, #2d4f1e); clip-path: polygon(15% 0%, 85% 0%, 100% 100%, 0% 100%); margin: 0 auto;"></div>' +
                        '<div style="position: absolute; top: 0px; left: 50%; transform: translateX(-50%); font-size: 80px; z-index: 110;">🎀</div>' +
                        '</div>';
                    canvas.append(baseHtml);

                    var centerX = canvas.width() / 2;
                    var centerY = canvas.height() - 200;

                    allFlowers.forEach(function (flower, index) {
                        var src = "/images/" + flower.img;
                        if (flower.name.indexOf('rose') !== -1) src = "/images/rose.jpg";
                        if (flower.name.indexOf('tulip') !== -1) src = "/images/tulip.png";

                        // פיזור רנדומלי בתוך הזר כדי שזה ייראה טבעי
                        var angle = 230 + (Math.random() * 80); // פריסה של 80 מעלות בחלק העליון
                        var rad = angle * Math.PI / 180;
                        var dist = 30 + (Math.random() * 80); // מרחקים שונים מהמרכז

                        var x = centerX + dist * Math.cos(rad) - 75;
                        var y = centerY + dist * Math.sin(rad) - 100;

                        var style = 'position: absolute; width: 150px; height: 150px; object-fit: contain; ' +
                            'left: ' + x + 'px; top: ' + y + 'px; ' +
                            'transform: rotate(' + (angle - 270) + 'deg); ' +
                            'transform-origin: bottom center; z-index: ' + (10 + index) + '; ' +
                            'filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));';

                        var img = $('<img src="' + src + '" class="flower-instance" style="' + style + '">');

                        img.on('error', function () {
                            var c = $(this).attr('src');
                            $(this).attr('src', c.includes('.jpg') ? c.replace('.jpg', '.png') : c.replace('.png', '.jpg'));
                        });

                        canvas.append(img);
                    });
                } else {
                    placeholder.show();
                    wrapping.hide();
                }
            }
        });
    </script>
}