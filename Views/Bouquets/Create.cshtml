@model LyaShop.Models.Bouquet

@{
    ViewData["Title"] = "Professional Bouquet Designer";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">💐 Design Your Luxury Bouquet</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Create" method="post" id="bouquetForm">
                @* שדה נסתר שישמור את ה-HTML של הזר בשביל הגלריה *@
                <input type="hidden" asp-for="BouquetDesignHtml" id="designHtmlInput" />

                <div class="card shadow-sm p-4 border-0">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Bouquet Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Summer Dream" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Add Flowers to Bouquet</label>
                        <div id="flowerControls" class="list-group mb-2">
                            @if (ViewBag.Flowers != null)
                            {
                                foreach (var flower in (IEnumerable<LyaShop.Models.Flower>)ViewBag.Flowers)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 bg-light mb-2 rounded">
                                        <span>@flower.Name <small class="text-muted">(₪@flower.Price)</small></span>
                                        <div class="input-group input-group-sm" style="width: 120px;">
                                            <button type="button" class="btn btn-outline-secondary btn-minus" data-id="@flower.Id">-</button>
                                            <input type="number" name="flower_@flower.Id" class="form-control text-center flower-qty"
                                                   value="0" min="0" 
                                                   data-id="@flower.Id" 
                                                   data-name="@flower.Name"
                                                   data-price="@flower.Price" 
                                                   data-img="@flower.ImagePath" readonly>
                                            <button type="button" class="btn btn-outline-secondary btn-plus" data-id="@flower.Id">+</button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Total Price (₪)</label>
                        <input asp-for="Price" id="totalPrice" class="form-control fw-bold bg-warning text-dark" type="number" step="0.01" required readonly value="0" />
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm fw-bold">Order This Bouquet</button>
                </div>
                
                @* כאן ייכנסו שדות נסתרים של מזהי הפרחים שנבחרו לצורך הקשר בבסיס הנתונים *@
                <div id="hiddenFields"></div>
            </form>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm h-100 bg-white" style="border: 1px solid #eee; position: relative; overflow: hidden; min-height: 600px;">
                @* זה ה"קנבס" שבו הזר נבנה ויזואלית *@
                <div id="bouquetCanvas" class="card-body p-0" style="position: relative; height: 100%; background: #fcfcfc;">
                    <div id="placeholderText" class="text-center text-muted" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                        <p class="fs-4">Select flowers to start designing!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // הוספת פרח
            $('.btn-plus').click(function () {
                var input = $(this).siblings('.flower-qty');
                input.val(parseInt(input.val()) + 1);
                updateBouquet();
            });

            // הסרת פרח
            $('.btn-minus').click(function () {
                var input = $(this).siblings('.flower-qty');
                if (parseInt(input.val()) > 0) {
                    input.val(parseInt(input.val()) - 1);
                    updateBouquet();
                }
            });

            // לפני שליחת הטופס - צילום מצב של ה-HTML לתוך השדה הנסתר
            $('#bouquetForm').on('submit', function() {
                // יוצרים עותק נקי של הקנבס בלי טקסטים מיותרים
                const canvasClone = $('#bouquetCanvas').clone();
                canvasClone.find('#placeholderText').remove();
                
                // שומרים את ה-HTML של העיצוב לתוך המודל
                $('#designHtmlInput').val(canvasClone.html());
            });

            function updateBouquet() {
                var canvas = $('#bouquetCanvas');
                var placeholder = $('#placeholderText');
                var hiddenFields = $('#hiddenFields');
                var totalPriceDisplay = $('#totalPrice');

                // ניקוי הקנבס והשדות הנסתרים לפני עדכון
                canvas.find('.flower-instance, .bouquet-base').remove();
                hiddenFields.empty();

                var allFlowers = [];
                var runningTotal = 0;

                $('.flower-qty').each(function () {
                    var qty = parseInt($(this).val());
                    var id = $(this).data('id');
                    var name = $(this).data('name').toLowerCase();
                    var img = $(this).data('img');
                    var price = parseFloat($(this).data('price')) || 0;

                    if (qty > 0) {
                        runningTotal += (qty * price);
                        for (var i = 0; i < qty; i++) {
                            allFlowers.push({ id: id, name: name, img: img });
                            // הוספת ה-ID של הפרח לשליחה ל-Controller
                            hiddenFields.append('<input type="hidden" name="selectedFlowers" value="' + id + '">');
                        }
                    }
                });

                // עדכון המחיר הסופי
                totalPriceDisplay.val(runningTotal.toFixed(2));

                if (allFlowers.length > 0) {
                    placeholder.hide();
                    
                    // הוספת בסיס הזר (הגבעולים והסרט)
                    var baseHtml = `
                        <div class="bouquet-base" style="position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); z-index: 100;">
                            <div style="width: 40px; height: 180px; background: linear-gradient(90deg, #1e3511, #2d4f1e); margin: 0 auto; clip-path: polygon(15% 0%, 85% 0%, 100% 100%, 0% 100%);"></div>
                            <div style="position: absolute; top: 0px; left: 50%; transform: translateX(-50%); font-size: 80px; z-index: 110;">🎀</div>
                        </div>`;
                    canvas.append(baseHtml);

                    // פיזור הפרחים בצורה רנדומלית יפה
                    allFlowers.forEach(function (flower, index) {
                        var angle = 230 + (Math.random() * 80); // זווית פיזור
                        var rad = angle * Math.PI / 180;
                        var dist = 50 + (Math.random() * 120); // מרחק מהמרכז

                        var x = (canvas.width() / 2) + dist * Math.cos(rad) - 75;
                        var y = (canvas.height() - 250) + dist * Math.sin(rad) - 75;

                        var style = `
                            position: absolute; 
                            width: 150px; 
                            height: 150px; 
                            object-fit: contain; 
                            left: ${x}px; 
                            top: ${y}px; 
                            z-index: ${10 + index}; 
                            transform: rotate(${angle - 270}deg); 
                            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));`;

                        canvas.append(`<img src="/images/${flower.img}" class="flower-instance" style="${style}">`);
                    });
                } else {
                    placeholder.show();
                }
            }
        });
    </script>
}