@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FloraLya</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LyaShop.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #fdfbf7;
            direction: rtl;
            text-align: right;
        }

        .navbar {
            background-color: #ffffff !important;
            box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        }

        .navbar-brand {
            font-family: 'Playfair Display', serif;
            color: #2b4a36 !important;
            font-weight: 600;
            font-size: 1.6rem;
        }

        .nav-link {
            color: #4a4a4a !important;
            font-weight: 500;
            margin: 0 10px;
        }

        .btn-create-nav {
            background-color: #2b4a36 !important;
            color: white !important;
            border-radius: 50px;
            padding: 6px 20px;
            transition: all 0.3s ease;
        }

            .btn-create-nav:hover {
                background-color: #b89a6c !important;
                transform: translateY(-2px);
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">FloraLya</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">דף הבית</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn-create-nav" asp-controller="Bouquets" asp-action="Create">✨ עצב זר אישי</a>
                        </li>

                        @{
                            var isAdmin = HttpContextAccessor.HttpContext.Session.GetString("IsAdmin") == "true";
                            var customerName = HttpContextAccessor.HttpContext.Session.GetString("CustomerName");
                        }

                        @* הכפתור יופיע רק אם המשתמש הוא באמת מנהל *@
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Admin" asp-action="Dashboard">⚙️ ניהול מערכת</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(customerName))
                        {
                            <li class="nav-item"><span class="nav-link">שלום, <b>@customerName</b> ✨</span></li>
                            <li class="nav-item"><a class="nav-link text-danger" asp-controller="Customers" asp-action="Logout">יציאה</a></li>
                        }
                        else if (isAdmin)
                        {
                            <li class="nav-item"><span class="nav-link text-danger fw-bold">מחובר כמנהל</span></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Logout">יציאה</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Customers" asp-action="Login">התחברות</a></li>
                            <li class="nav-item"><a class="nav-link text-muted" style="font-size:0.7rem; padding-top:14px;" asp-controller="Admin" asp-action="Login">מנהל</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center py-3">
        <div class="container">&copy; 2026 - FloraLya</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>