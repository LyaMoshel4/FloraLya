@{
    ViewData["Title"] = "Home - FloraLya";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap');

    body {
        background-color: #fdfbf7;
        font-family: 'Montserrat', sans-serif;
        overflow-x: hidden;
    }

    .hero-container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 85vh;
        text-align: center;
        padding: 2rem;
        animation: fadeIn 1.2s ease-out;
    }

    /* הטריק שממיס את הריבוע הלבן של התמונה אל תוך רקע האתר */
    .brand-logo {
        max-width: 480px;
        width: 100%;
        height: auto;
        margin-bottom: 1.5rem;
        mix-blend-mode: multiply; /* מעלים את הרקע הלבן האטום */
        transition: transform 0.5s ease;
    }

        .brand-logo:hover {
            transform: scale(1.02);
        }

    .subtitle {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        color: #b89a6c;
        font-size: 1.8rem;
        font-weight: 400;
        margin-bottom: 3.5rem;
        letter-spacing: 0.5px;
    }

    .btn-floralya {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        color: #ffffff;
        background-color: #2b4a36;
        padding: 16px 50px;
        border-radius: 50px;
        border: 2px solid #2b4a36;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 8px 25px rgba(43, 74, 54, 0.25);
        position: relative;
        z-index: 1;
    }

        .btn-floralya:hover {
            background-color: transparent;
            color: #2b4a36;
            box-shadow: 0 4px 10px rgba(43, 74, 54, 0.1);
            transform: translateY(-3px);
            text-decoration: none;
        }

        .btn-floralya:active {
            transform: translateY(-1px);
        }

    .features-section {
        display: flex;
        justify-content: center;
        gap: 4rem;
        margin-top: 4.5rem;
        width: 100%;
        max-width: 900px;
        border-top: 1px solid rgba(184, 154, 108, 0.15);
        padding-top: 3rem;
        animation: fadeIn 1.8s ease-out;
    }

    .feature-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .feature-icon {
        font-size: 1.5rem;
        color: #2b4a36;
    }

    .feature-text {
        font-size: 0.9rem;
        font-weight: 500;
        color: #6c757d;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .brand-logo {
            max-width: 320px;
        }

        .subtitle {
            font-size: 1.4rem;
            margin-bottom: 2.5rem;
        }

        .btn-floralya {
            font-size: 1.2rem;
            padding: 12px 35px;
        }

        .features-section {
            flex-direction: column;
            gap: 2rem;
            margin-top: 2.5rem;
            padding-top: 2rem;
        }
    }
</style>

<div class="hero-container">
    <img src="~/images/Gemini_Generated_Image_2ykykv2ykykv2yky.jpeg"
         onerror="this.onerror=null; this.src='/images/Gemini_Generated_Image_2ykykv2ykykv2yky.png';"
         alt="FloraLya Logo"
         class="brand-logo" />

    <div class="subtitle">Where Nature Meets Your Imagination</div>

    <a asp-controller="Bouquets" asp-action="Create" class="btn-floralya">Start Designing</a>

    <div class="features-section">
        <div class="feature-item">
            <span class="feature-icon">✨</span>
            <span class="feature-text">Custom 3D Designer</span>
        </div>
        <div class="feature-item">
            <span class="feature-icon">🌸</span>
            <span class="feature-text">Fresh Premium Flowers</span>
        </div>
        <div class="feature-item">
            <span class="feature-icon">🕊️</span>
            <span class="feature-text">Fast & Elegant Delivery</span>
        </div>
    </div>
</div>