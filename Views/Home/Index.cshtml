@{
    ViewData["Title"] = "Home - FloraLya";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap');

    body {
        background-color: #fdfbf7;
        font-family: 'Montserrat', sans-serif;
    }

    .hero-container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 75vh;
        text-align: center;
    }

    .brand-logo {
        max-width: 350px;
        height: auto;
        margin-bottom: 1.5rem;
        filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.05));
    }

    .btn-floralya {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        letter-spacing: 1px;
        color: #ffffff;
        background-color: #2b4a36;
        padding: 12px 35px;
        border-radius: 50px;
        border: 2px solid #2b4a36;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(43, 74, 54, 0.2);
    }

        .btn-floralya:hover {
            background-color: transparent;
            color: #2b4a36;
            box-shadow: none;
            text-decoration: none;
        }

    .subtitle {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        color: #b89a6c;
        font-size: 1.3rem;
        margin-bottom: 2.5rem;
    }
</style>

<div class="hero-container">
    <img src="~/images/Gemini_Generated_Image_2ykykv2ykykv2yky.jpeg" onerror="this.onerror=null; this.src='/images/Gemini_Generated_Image_2ykykv2ykykv2yky.png';" alt="FloraLya Logo" class="brand-logo" />

    <div class="subtitle">Where Nature Meets Your Imagination</div>

    <a href="/Flowers/Designer" class="btn-floralya">Start Designing</a>
</div>